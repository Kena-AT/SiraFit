# Ignore generated and binary artifacts
*.docx
*.doc
*.pdf

# Design files
*.pen
*.sketch
*.fig
*.xd
*.psd

# OS files
.DS_Store
Thumbs.db

# Python caches
__pycache__/
*.py[cod]

# Node modules
frontend/node_modules
backend/node_modules

# Environment files (keep .env.example if needed)
.env
.env.*

# Logs
*.log
logs/

# IDE/editor settings
.vscode/
.idea/

venv/
.venv/
env/

# Keep requirements.txt (needed for CI)
!requirements.txt